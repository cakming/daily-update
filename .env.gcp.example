# =============================================================================
# GCP VM production environment  —  copy to .env and fill in real values.
#
#   cp .env.gcp.example .env
#   docker compose -f docker-compose.gcp.yml --env-file .env up -d --build
#
# NEVER commit the filled-in .env. It is already covered by .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Database  —  EXTERNAL MongoDB on a separate in-network server.
# Use the Mongo server's PRIVATE IP (same VPC), not a public address.
# authSource is usually "admin" when the user was created in the admin db.
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://appuser:CHANGE_ME@10.128.0.5:27017/daily-update?authSource=admin

# -----------------------------------------------------------------------------
# Public URLs  —  the domain that points at this VM.
# CLIENT_URL is used for CORS + links in emails/notifications.
# VITE_API_URL is baked into the frontend build; keep it same-origin (/api)
# so browser requests hit the reverse proxy with no CORS.
# -----------------------------------------------------------------------------
CLIENT_URL=https://daily-update.example.com
VITE_API_URL=https://daily-update.example.com/api

# -----------------------------------------------------------------------------
# Auth
#   Generate a strong secret:  openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=GENERATE_WITH_openssl_rand_-hex_64
JWT_EXPIRE=7d

# -----------------------------------------------------------------------------
# Anthropic (Claude) API
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# -----------------------------------------------------------------------------
# Email / SMTP  —  used for verification, password reset, and daily digests.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Daily Update

# -----------------------------------------------------------------------------
# Telegram bot (optional)  —  leave blank to disable the bot on boot.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Google Chat / Slack outbound webhooks (optional)
# -----------------------------------------------------------------------------
GOOGLE_CHAT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Error tracking (optional but recommended)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# TLS certificate directory on the VM, mounted read-only into the proxy.
# With certbot's default layout this is /etc/letsencrypt (contains live/...).
# -----------------------------------------------------------------------------
TLS_CERT_DIR=/etc/letsencrypt
